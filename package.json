{
  "name": "@apexdevtools/test-runner",
  "version": "3.3.1-beta.0",
  "description": "Apex parallel test runner with reliability goodness",
  "author": {
    "name": "Apex Dev Tools Team",
    "email": "apexdevtools@gmail.com",
    "url": "https://github.com/apex-dev-tools"
  },
  "main": "./lib/src/index.js",
  "license": "BSD-3-Clause",
  "files": [
    "lib/**/*",
    "CHANGELOG.md"
  ],
  "scripts": {
    "build": "tsc",
    "clean": "rm -rf ./lib/",
    "commit": "cz",
    "lint": "eslint --cache --cache-location .eslintcache ./src --fix",
    "prepare": "husky",
    "run:script": "ts-node-transpile-only",
    "test": "jest --coverage --runInBand",
    "test:pack": "webpack --mode production --devtool hidden-source-map",
    "test:watch": "jest --watch"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/apex-dev-tools/test-runner.git"
  },
  "keywords": [
    "salesforce",
    "apex",
    "apexlink"
  ],
  "bugs": {
    "url": "https://github.com/apex-dev-tools/test-runner/issues"
  },
  "homepage": "https://github.com/apex-dev-tools/test-runner#readme",
  "packageManager": "pnpm@10.23.0",
  "engines": {
    "node": "^20.19.0 || ^22.13.0 || >=24"
  },
  "dependencies": {
    "@apexdevtools/sfdx-auth-helper": "^2.1.1",
    "@salesforce/apex-node": "^1.6.2",
    "@salesforce/core": "^4.3.11",
    "@salesforce/kit": "^3.2.6",
    "istanbul-lib-coverage": "^3.2.2",
    "istanbul-lib-report": "^3.0.1",
    "istanbul-reports": "^3.2.0",
    "jsforce": "^1.11.0",
    "moment": "^2.30.1",
    "table": "^6.9.0",
    "ts-retry-promise": "^0.8.1"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@ryansonshine/commitizen": "^4.2.8",
    "@ryansonshine/cz-conventional-changelog": "^3.3.4",
    "@salesforce/ts-sinon": "^1.4.34",
    "@types/chai": "^4.3.20",
    "@types/istanbul-lib-coverage": "^2.0.6",
    "@types/istanbul-lib-report": "^3.0.3",
    "@types/istanbul-reports": "^3.0.4",
    "@types/jest": "^30.0.0",
    "@types/jsforce": "^1.11.6",
    "@types/lodash": "^4.17.24",
    "@types/node": "^22.19.17",
    "@types/sinon": "^21.0.1",
    "@types/xml2js": "^0.4.14",
    "chai": "^4.5.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "husky": "^9.1.7",
    "jest": "^30.4.2",
    "lint-staged": "^17.0.7",
    "prettier": "^3.8.4",
    "sinon": "^22.0.0",
    "ts-jest": "^29.4.11",
    "ts-node": "^10.9.2",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0",
    "webpack": "^5.107.2",
    "webpack-cli": "^7.0.3",
    "xml2js": "^0.6.2"
  },
  "config": {
    "commitizen": {
      "path": "./node_modules/@ryansonshine/cz-conventional-changelog"
    }
  },
  "lint-staged": {
    "*.ts": "eslint --cache --cache-location .eslintcache --fix"
  }
}
